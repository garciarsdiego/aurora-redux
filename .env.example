# =============================================================================
# Aurora-Redux — example environment
# Copy to `.env` and fill in the keys for whichever providers you use.
# The engine talks to LLMs three ways, chosen per task by the MODEL-ID PREFIX:
#   • direct OpenAI-compatible APIs  (kimi/ · minimax/ · glm/)
#   • local CLI subscriptions        (claude-cli/ · codex-cli/)
#   • cli_spawn agents               (executor_hint: cli:claude | cli:codex | cli:gemini)
# No external gateway/router process is required.
# =============================================================================

# --- Required so the daemon boots without a model-catalog service ------------
OMNIFORGE_SKIP_MODEL_VALIDATION=true
# Use the simple legacy code paths (recommended for the direct/CLI transports).
OMNIFORGE_USE_PERSONAS=false
# cli_spawn agents need write/exec; set true only for read-only sandboxing.
CLI_SAFE_MODE=false

# --- Direct OpenAI-compatible providers (fill the ones you have) --------------
# Each key routes model-ids with that prefix straight to the provider's API.
KIMI_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
# Endpoints have sensible defaults; override only if your plan differs.
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# Reasoning models spend part of their budget on hidden thinking — keep generous.
DIRECT_PROVIDER_MAX_TOKENS=32000

# --- Roles: which model plays each part (prefix decides the transport) --------
# Decomposer via the Claude CLI (uses your logged-in `claude` session, $0/token).
DECOMPOSER_MODEL=claude-cli/
# Reviewer: strong but slow via Codex; swap to glm/glm-5.2 or claude-cli/ if it
# bottlenecks (the reviewer runs on every task that has acceptance_criteria).
REVIEWER_MODEL=codex-cli/gpt-5.5
# Default model for llm_call tasks.
TASK_MODEL=kimi/kimi-for-coding
# Consolidator (large context helps).
CONSOLIDATOR_MODEL=glm/glm-5.2
# Reviewer via Codex can take minutes — raise the cap accordingly.
MAX_REVIEW_TIME_MS=600000

# --- Optional: CLI transport timeouts (ms) -----------------------------------
# CLAUDE_CLI_TIMEOUT_MS=180000
# CODEX_CLI_TIMEOUT_MS=600000

# --- Optional: legacy external router (only used as a fallback) ---------------
# Left blank on purpose — Aurora-Redux does NOT require it.
# OMNIROUTE_URL=http://localhost:20228
# OMNIROUTE_API_KEY=
OMNIROUTE_MAX_RETRIES=0

# --- Optional: Telegram HITL notifications (off by default) -------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
