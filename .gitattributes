# Normalize line endings across platforms (Linux + macOS + Windows clones)
# Default: text files use LF on disk in the index; checkout follows core.autocrlf.
* text=auto eol=lf

# Native Windows scripts must keep CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# POSIX shell scripts must keep LF
*.sh        text eol=lf

# Common source — explicit so editors that touch via auto-detect agree
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf

# Binary — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary

# Lockfiles — generated, mark as such for review tools
pnpm-lock.yaml      linguist-generated=true
package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true

# Generated dirs — collapse in diff UIs
dist/**             linguist-generated=true
out/**              linguist-generated=true
coverage/**         linguist-generated=true

# Vendored inline-asset bundles — not auto-generated, but large hand-curated
# blobs of HTML/CSS/JS that drown out normal diffs. Mark as vendored so
# GitHub language stats and review tooling collapse them by default.
# Edit notes are in the file's leading block comment.
src/mcp/dashboard-assets.ts   linguist-vendored=true
